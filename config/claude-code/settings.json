      "Bash(aws s3 ls:*)",
      "Bash(aws sts:*)",
      "Bash(aws-vault --version)",
      "Bash(aws-vault exec:*)",
      "Bash(aws-vault list:*)",
      "Bash(cat:*)",
      "Bash(chmod:*)",
      "Bash(diff:*)",
      "Bash(docker build:*)",
      "Bash(docker compose:*)",
      "Bash(docker container prune:*)",
      "Bash(docker exec:*)",
      "Bash(docker image prune:*)",
      "Bash(docker images:*)",
      "Bash(docker info:*)",
      "Bash(docker inspect:*)",
      "Bash(docker logs:*)",
      "Bash(docker network prune:*)",
      "Bash(docker ps:*)",
      "Bash(docker run:*)",
      "Bash(docker stats:*)",
      "Bash(docker system prune:*)",
      "Bash(docker version:*)",
      "Bash(docker volume prune:*)",
      "Bash(echo:*)",
      "Bash(find:*)",
      "Bash(git -C * add:*)",
      "Bash(git -C * branch:*)",
      "Bash(git -C * commit:*)",
      "Bash(git -C * diff:*)",
      "Bash(git -C * log:*)",
      "Bash(git -C * ls-remote:*)",
      "Bash(git -C * show:*)",
      "Bash(git -C * status:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git check-ignore:*)",
      "Bash(git commit:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git ls-remote:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(pnpm --filter * build:*)",
      "Bash(rg:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run pytest:*)",
      "Bash(ruff check:*)",
      "Bash(tail:*)",
